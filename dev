#!/usr/bin/env bash
set -euo pipefail

# dev тАФ SeaPortal developer toolkit
# Usage: dev [command]    Run a command directly
#        dev              Interactive picker

cd "$(dirname "$0")"

BOLD=$'\033[1m'
ACCENT=$'\033[38;2;251;191;36m'
MUTED=$'\033[38;2;90;100;128m'
SUCCESS=$'\033[38;2;0;229;204m'
ERROR=$'\033[38;2;230;57;70m'
NC=$'\033[0m'

# тФАтФА Commands тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
COMMANDS=(
  "build:ЁЯЪА:Build binary"
  "run:ЁЯПГ:Build & run with test URL"
  "check:ЁЯзк:All checks (format, vet, lint, test)"
  "test:ЁЯФм:Run tests"
  "test race:ЁЯПБ:Run tests with race detector"
  "coverage:ЁЯУК:Run tests with coverage"
  "lint:ЁЯФН:Run golangci-lint"
  "fmt:тЬи:Format code"
  "vet:ЁЯй║:Run go vet"
  "fuzz:ЁЯО▓:Run fuzz tests (30s)"
  "benchmark:тЪб:Run benchmarks"
  "doctor:ЁЯПе:Check dev environment"
  "e2e:ЁЯР│:E2E tests (Docker)"
)

# тФАтФА Helpers тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА

show_help() {
  echo ""
  echo "  ${ACCENT}${BOLD}ЁЯМК SeaPortal Dev${NC}"
  echo ""
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    printf "  ${SUCCESS}%s${NC} ${BOLD}%-12s${NC} ${MUTED}%s${NC}\n" "$emoji" "$name" "$desc"
  done
  echo ""
  echo "  ${MUTED}Usage: ./dev [command]${NC}"
  echo ""
}

run_command() {
  local target="$1"

  echo ""

  case "$target" in
    "build")
      echo "  ${ACCENT}${BOLD}ЁЯЪА Building seaportal${NC}"
      echo ""
      go build -o seaportal ./cmd/seaportal
      echo "  ${SUCCESS}тЬУ${NC} Built: ./seaportal"
      ;;
    "run")
      echo "  ${ACCENT}${BOLD}ЁЯПГ Build & run${NC}"
      echo ""
      go build -o seaportal ./cmd/seaportal
      ./seaportal --json https://pinchtab.com | head -30
      ;;
    "check")
      echo "  ${ACCENT}${BOLD}ЁЯзк Running checks${NC}"
      echo ""
      exec bash scripts/check.sh
      ;;
    "test")
      echo "  ${ACCENT}${BOLD}ЁЯФм Running tests${NC}"
      echo ""
      shift_args="${2:-}"
      if [ "$shift_args" = "race" ]; then
        go test ./... -count=1 -race -v
      else
        exec bash scripts/test.sh
      fi
      ;;
    "test race")
      echo "  ${ACCENT}${BOLD}ЁЯПБ Tests with race detector${NC}"
      echo ""
      go test ./... -count=1 -race -v
      ;;
    "coverage")
      echo "  ${ACCENT}${BOLD}ЁЯУК Coverage${NC}"
      echo ""
      go test ./... -count=1 -coverprofile=coverage.out -covermode=atomic
      go tool cover -func=coverage.out | tail -1
      echo ""
      echo "  ${MUTED}Full report: go tool cover -html=coverage.out${NC}"
      ;;
    "lint")
      echo "  ${ACCENT}${BOLD}ЁЯФН Linting${NC}"
      echo ""
      if command -v golangci-lint &>/dev/null; then
        golangci-lint run ./...
        echo "  ${SUCCESS}тЬУ${NC} golangci-lint"
      else
        echo "  ${ERROR}тЬЧ golangci-lint not installed${NC}"
        echo "  ${MUTED}Install: brew install golangci-lint${NC}"
        exit 1
      fi
      ;;
    "fmt")
      echo "  ${ACCENT}${BOLD}тЬи Formatting${NC}"
      echo ""
      gofmt -w .
      echo "  ${SUCCESS}тЬУ${NC} gofmt"
      ;;
    "vet")
      echo "  ${ACCENT}${BOLD}ЁЯй║ Vet${NC}"
      echo ""
      go vet ./...
      echo "  ${SUCCESS}тЬУ${NC} go vet"
      ;;
    "fuzz")
      echo "  ${ACCENT}${BOLD}ЁЯО▓ Fuzz tests${NC}"
      echo ""
      FUZZTIME="${2:-30s}"
      echo "  ${MUTED}Duration: $FUZZTIME${NC}"
      echo ""
      for f in $(grep -rl 'func Fuzz' --include='*_test.go' . 2>/dev/null | head -20); do
        pkg=$(dirname "$f")
        for fn in $(grep -oP 'func \KFuzz\w+' "$f"); do
          echo "  Running $fn in $pkg..."
          go test "$pkg" -fuzz="$fn" -fuzztime="$FUZZTIME"
        done
      done
      echo ""
      echo "  ${SUCCESS}тЬУ${NC} Fuzz complete"
      ;;
    "benchmark")
      echo "  ${ACCENT}${BOLD}тЪб Benchmarks${NC}"
      echo ""
      if [ -d benchmark ]; then
        go test ./benchmark/ -bench=. -benchmem -count=1
      else
        echo "  ${MUTED}No benchmark/ directory found${NC}"
      fi
      ;;
    "doctor")
      echo "  ${ACCENT}${BOLD}ЁЯПе Doctor${NC}"
      echo ""
      exec bash scripts/doctor.sh
      ;;
    "e2e")
      echo "  ${ACCENT}${BOLD}ЁЯР│ E2E tests (Docker)${NC}"
      echo ""
      
      # Check for docker compose
      COMPOSE_CMD=""
      if docker compose version &>/dev/null; then
        COMPOSE_CMD="docker compose"
      elif command -v docker-compose &>/dev/null; then
        COMPOSE_CMD="docker-compose"
      else
        echo "  ${ERROR}тЬЧ Docker Compose not found${NC}"
        echo ""
        echo "  Install with: brew install docker-compose"
        echo "  Or enable Docker Compose plugin in Docker Desktop"
        exit 1
      fi
      
      echo "Building binary for Linux..."
      CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o tests/e2e/runner/seaportal ./cmd/seaportal
      echo ""
      exec $COMPOSE_CMD -f tests/e2e/docker-compose.yml up --build --abort-on-container-exit --exit-code-from runner
      ;;
    *)
      echo "  ${ERROR}Unknown command: $target${NC}"
      show_help
      exit 1
      ;;
  esac
}

pick_with_gum() {
  local options=()
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    options+=("$(printf '%s %-12s %s' "$emoji" "$name" "$desc")")
  done

  local choice
  choice=$(printf '%s\n' "${options[@]}" | gum choose \
    --header "ЁЯМК SeaPortal Dev" \
    --header.foreground "#fbbf24" \
    --cursor.foreground "#00e5cc" \
    --selected.foreground "#00e5cc" \
    --item.foreground "#8892b0")

  local picked
  picked=$(echo "$choice" | awk '{print $2}')
  printf '\033[2J\033[H'
  run_command "$picked"
}

pick_with_select() {
  echo ""
  echo "  ${ACCENT}${BOLD}ЁЯМК SeaPortal Dev${NC}"
  echo ""

  local names=()
  local i=1
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    printf "  ${MUTED}[%d]${NC} ${SUCCESS}%s${NC} ${BOLD}%-12s${NC} ${MUTED}%s${NC}\n" "$i" "$emoji" "$name" "$desc"
    names+=("$name")
    i=$((i + 1))
  done

  echo ""
  echo -ne "  ${BOLD}Pick [1-${#COMMANDS[@]}]:${NC} "
  read -r choice

  if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#COMMANDS[@]} ]; then
    run_command "${names[$((choice - 1))]}"
  else
    run_command "$choice"
  fi
}

# тФАтФА Main тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА

if [ $# -gt 0 ]; then
  case "$1" in
    -h|--help|help) show_help; exit 0 ;;
    *) run_command "$1" ;;
  esac
  exit 0
fi

# No args тЖТ interactive picker
if command -v gum &>/dev/null; then
  pick_with_gum
else
  pick_with_select
fi
